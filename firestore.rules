rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /*
      VERSION TRANSICIONAL

      Objetivo:
      - no romper el flujo actual de invitados + PIN
      - no romper lecturas amplias de congregaciones y módulos
      - cerrar ataques obvios sobre usuarios y superadmin

      Qué sigue abierto a propósito por compatibilidad:
      - lectura de congregaciones
      - lectura/escritura de subcolecciones usadas por invitados y módulos actuales
      - PINs de módulos que hoy dependen del cliente

      Qué se cierra ya:
      - config/superadmin
      - auto-escalada de roles/permisos en usuarios/{uid}
      - edición arbitraria de campos sensibles del perfil
    */

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasProfile() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function me() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return hasProfile() &&
        me().appRoles is list &&
        role in me().appRoles;
    }

    function isAdminGeneral() {
      return hasRole('admin_general');
    }

    function sameCongreAsUser(userData) {
      return hasProfile() &&
        hasRole('admin_congre') &&
        userData.congregacionId == me().congregacionId;
    }

    function isSafeSelfRoleCreate() {
      return request.resource.data.appRoles is list &&
        request.resource.data.appRoles.size() == 1 &&
        request.resource.data.appRoles[0] in ['publicador', 'pendiente', 'anonimo'] &&
        request.resource.data.appRol == request.resource.data.appRoles[0] &&
        (
          (request.resource.data.appRol == 'anonimo' &&
            request.resource.data.matchEstado == 'anonimo' &&
            request.resource.data.isAnonymous == true) ||
          (request.resource.data.appRol == 'pendiente' &&
            request.resource.data.matchEstado == 'pendiente' &&
            request.resource.data.isAnonymous == false) ||
          (request.resource.data.appRol == 'publicador' &&
            request.resource.data.matchEstado in ['ok', 'sin_match'] &&
            request.resource.data.isAnonymous == false)
        );
    }

    function isValidManagedRoleUpdate() {
      return request.resource.data.appRoles is list &&
        request.resource.data.appRoles.size() > 0 &&
        request.resource.data.appRol == request.resource.data.appRoles[0];
    }

    match /config/superadmin {
      allow read: if isAdminGeneral();
      allow write: if false;
    }

    match /config/{docId} {
      allow read, write: if false;
    }

    match /usuarios/{uid} {
      allow read: if isSelf(uid) || isAdminGeneral() || sameCongreAsUser(resource.data);

      allow create: if isSelf(uid) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'birthDate',
          'sexo',
          'matchedPublisherId',
          'congregacionId',
          'appRol',
          'appRoles',
          'matchEstado',
          'isAnonymous',
          'primerLogin',
          'createdAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'birthDate',
          'sexo',
          'matchedPublisherId',
          'congregacionId',
          'appRol',
          'appRoles',
          'grupoEncargado',
          'matchEstado',
          'isAnonymous',
          'primerLogin',
          'createdAt'
        ]) &&
        isSafeSelfRoleCreate();

      allow update: if
        (
          isSelf(uid) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'displayName',
            'photoURL',
            'birthDate',
            'sexo',
            'primerLogin'
          ])
        ) ||
        (
          (
            isAdminGeneral() ||
            sameCongreAsUser(resource.data)
          ) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'appRol',
            'appRoles',
            'grupoEncargado',
            'matchEstado',
            'matchedPublisherId'
          ]) &&
          isValidManagedRoleUpdate()
        );

      allow delete: if false;

      match /predicacion/{mes} {
        allow read, write: if isSelf(uid);

        match /dias/{dia} {
          allow read, write: if isSelf(uid);
        }
      }

      match /revisitas/{id} {
        allow read, write: if isSelf(uid);
      }

      match /estudios/{id} {
        allow read, write: if isSelf(uid);
      }
    }

    /*
      Compatibilidad actual:
      se mantiene abierto el árbol de congregaciones para no romper la app.

      Cuando migremos a una versión más estricta, esto se reemplaza por
      reglas por congregación/rol.
    */
    match /congregaciones/{congreId} {
      allow read: if true;
      allow write: if signedIn();

      match /config_privada/{docId} {
        allow read, write: if signedIn();
      }

      match /{document=**} {
        allow read: if true;
        allow write: if signedIn();
      }
    }
  }
}
